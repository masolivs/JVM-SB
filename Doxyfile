#---------------------------------------------------------------------------
# Projeto
#---------------------------------------------------------------------------
PROJECT_NAME           = "JVM-Interpretador"
PROJECT_NUMBER         = "2026.1"
PROJECT_BRIEF          = "Implementacao de uma Java Virtual Machine em C++11 — Software Basico UnB"
PROJECT_LOGO           =
OUTPUT_DIRECTORY       = docs

#---------------------------------------------------------------------------
# Entrada
#---------------------------------------------------------------------------
INPUT                  = include src README.md
FILE_PATTERNS          = *.h *.cpp *.md
RECURSIVE              = YES
USE_MDFILE_AS_MAINPAGE = README.md

#---------------------------------------------------------------------------
# Extracao
#---------------------------------------------------------------------------
EXTRACT_ALL            = YES
EXTRACT_PRIVATE        = YES
EXTRACT_STATIC         = YES
EXTRACT_LOCAL_METHODS  = YES

#---------------------------------------------------------------------------
# Saida HTML
#---------------------------------------------------------------------------
GENERATE_HTML          = YES
HTML_OUTPUT            = html
GENERATE_LATEX         = NO
GENERATE_TREEVIEW      = YES
DISABLE_INDEX          = NO
FULL_SIDEBAR           = NO
HTML_COLORSTYLE        = LIGHT

#---------------------------------------------------------------------------
# Grafos de chamada
#---------------------------------------------------------------------------
HAVE_DOT               = YES
CALL_GRAPH             = YES
CALLER_GRAPH           = YES
DOT_IMAGE_FORMAT       = svg
INTERACTIVE_SVG        = YES
DOT_GRAPH_MAX_NODES    = 100
MAX_DOT_GRAPH_DEPTH    = 0

#---------------------------------------------------------------------------
# Warnings e qualidade
#---------------------------------------------------------------------------
WARN_IF_UNDOCUMENTED   = YES
WARN_IF_DOC_ERROR      = YES
QUIET                  = NO

#---------------------------------------------------------------------------
# Javadoc / Doxygen style
#---------------------------------------------------------------------------
JAVADOC_AUTOBRIEF      = YES
OPTIMIZE_OUTPUT_FOR_C  = NO
OPTIMIZE_FOR_FORTRAN   = NO

#---------------------------------------------------------------------------
# Preprocessador
#---------------------------------------------------------------------------
ENABLE_PREPROCESSING   = YES
MACRO_EXPANSION        = NO

#---------------------------------------------------------------------------
# Source browser (mostra o codigo fonte na doc)
#---------------------------------------------------------------------------
SOURCE_BROWSER         = YES
INLINE_SOURCES         = NO
STRIP_CODE_COMMENTS    = NO

#---------------------------------------------------------------------------
# Encoding
#---------------------------------------------------------------------------
DOXYFILE_ENCODING      = UTF-8
INPUT_ENCODING         = UTF-8
